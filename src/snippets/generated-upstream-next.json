    "pagination": {
      "description": "https://shadcn-svelte.com/docs/components/pagination",
      "import": [
        "import * as Pagination from \"$lib/components/ui/pagination/index.js\";"
      ],
      "usage": [
        "<Pagination.Root count={100} perPage={10}>",
        "  {#snippet children({ pages, currentPage })}",
        "    <Pagination.Content>",
        "      <Pagination.Item>",
        "        <Pagination.Previous />",
        "      </Pagination.Item>",
        "      {#each pages as page (page.key)}",
        "        {#if page.type === \"ellipsis\"}",
        "          <Pagination.Item>",
        "            <Pagination.Ellipsis />",
        "          </Pagination.Item>",
        "        {:else}",
        "          <Pagination.Item>",
        "            <Pagination.Link {page} isActive={currentPage === page.value}>",
        "              {page.value}",
        "            </Pagination.Link>",
        "          </Pagination.Item>",
        "        {/if}",
        "      {/each}",
        "      <Pagination.Item>",
        "        <Pagination.Next />",
        "      </Pagination.Item>",
        "    </Pagination.Content>",
        "  {/snippet}",
